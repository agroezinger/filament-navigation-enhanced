{
    "name": "agroezinger/filament-navigation-enhanced",
    "description": "Adds collapsible child-item support to the Filament sidebar navigation.",
    "type": "library",
    "homepage": "https://github.com/agroezinger/filament-navigation-enhanced/",
    "license": "MIT",
    "authors": [
        {
            "name": "Alexander Groezinger",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "Agroezinger\\FilamentNavigationEnhanced\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Agroezinger\\FilamentNavigationEnhanced\\NavigationEnhancedServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
